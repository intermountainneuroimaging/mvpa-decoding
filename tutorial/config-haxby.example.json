  "model": {
    "desc": "haxby_object_classifier",
    "mask": {
      "mask_pattern": "sub-{subject}/masks/native_epi_mask.nii.gz"
    },
    "featureSelection": {
      "model": "ANOVA",
      "feat_p": 0.05
    },
    "classifier": {
      "name": "sklearn.linear_model.LogisticRegression",
      "params": {
        "penalty": "l2",
        "C": 0.5,
        "solver": "lbfgs",
        "max_iter": 10000,
        "class_weight": "balanced"
      }
    },
    "cv": {
      "strategy": "GroupKFold",
      "n_splits": "infer"
