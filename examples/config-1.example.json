{
  "config_version": "1.0",
  "created_by": "AKH",
  "notes": "MVPA positive/negative; masking on grey matter",

  "event_extraction": {
    "bids_root": "<path to raw bids data (where events.tsv files live)>",
    "derivatives_root": "<path to preprocessed/derivative data, e.g. an fMRIPrep derivatives folder -- omit to search under bids_root instead>",
    "bold_glob": "sub-{subject}/ses-{session}/func/sub-{subject}_ses-{session}_task-{task}_dir-{dir}_run-{run}_space-MNI152NLin2009cAsym_desc-preproc_bold.nii.gz",
    "events_glob": "**/*_events.tsv",
    "hemodynamic_lag": 4.6,
    "output_file": "master_spreadsheet.csv",
    "expected_events_file": "examples/expected_events.example.json"
  },

  "model_conditions": {
    "training": {
      "conditions": {
        "positive": {
          "and": [
            {"column": "task", "match": "exact", "value": "loc"},
            {"column": "trial_type", "match": "regex", "value": ".*positive.*"}
          ]
        },
        "negative": {
          "and": [
            {"column": "task", "match": "exact", "value": "loc"},
            {"column": "trial_type", "match": "regex", "value": ".*negative.*"}
          ]
        }
      }
    },

    "testing": {
      "conditions": {
        "positive": {"column": "task", "match": "exact", "value": "WMpos"},
        "negative": {"column": "task", "match": "exact", "value": "WMneg"}
      }
    },

    "timecourse_decoding": {
      "conditions": {
        "positive": {
          "and": [
            {"column": "task", "match": "exact", "value": "WMpos"},
            {"not": {"column": "trial_type", "match": "regex", "value": "view_.*"}}
          ]
        },
        "negative": {
          "and": [
            {"column": "task", "match": "exact", "value": "WMneg"},
            {"not": {"column": "trial_type", "match": "regex", "value": "view_.*"}}
          ]
        }
      },
      "window": {
        "start": {"reference": "onset", "offset_seconds": 0},
        "end": {"reference": "offset_end", "offset_seconds": 10}
      }
    }
  },

  "model": {
    "desc": "gm_valence_classifier",
    "mask": {
      "mask_root": "<optional: path to mask files, if not co-located with derivatives_root/bids_root>",
      "mask_pattern": "sub-{subject}/ses-{session}/masks/native_gm_transformed_mask.nii.gz"
    },
    "featureSelection": {
      "model": "ANOVA",
      "feat_p": 0.05
    },
    "classifier": {
      "name": "sklearn.linear_model.LogisticRegression",
      "params": {
        "penalty": "l2",
        "C": 0.5,
        "solver": "lbfgs",
        "max_iter": 10000,
        "class_weight": "balanced"
      }
    },
    "cv": {
      "strategy": "GroupKFold",
      "n_splits": "infer"
    }
  }
}
